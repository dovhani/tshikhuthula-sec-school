---
const { currentPage = 'home' } = Astro.props;

const menuItems = [
    {
        key: 'enrol',
        title: 'Enrol Now',
        href: '/enrolment',
        icon: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="12" y1="18" x2="12" y2="12"></line><line x1="9" y1="15" x2="15" y2="15"></line></svg>'
    },
    {
        key: 'home',
        title: 'Home',
        href: '/',
        icon: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>'
    },
    { 
        key: 'our-school', 
        title: 'Our School', 
        href: '#',
        icon: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path></svg>',
        children: [
            { key: 'school-overview', title: 'Our School Overview', href: '/our-school' },
            { key: 'about', title: 'About Us', href: '/about' },
            { key: 'curriculum', title: 'Curriculum', href: '/curriculum' },
            { key: 'admission', title: 'Admission & Enrolment', href: '/enrolment' },
            { key: 'student-life', title: 'Student Life', href: '/student-life' },
            { key: 'sub-gallery', title: 'Gallery', href: '/gallery' },
            { key: 'wall-of-fame', title: 'Wall of Fame', href: '/wall-of-fame' },
            { key: 'policies', title: 'Policies & Documents', href: '/policies' },
            { key: 'memories', title: 'Memories', href: '/memories' },
        ]
    },
    { 
        key: 'calendar-events', 
        title: 'Calendar',
        href: '/calendar',
        icon: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>'
    },
    {
        key: 'contact',
        title: 'Contact Us',
        href: '/contact',
        icon: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>'
    }
];

const contactInfo = {
    phone: "(015) 123 4567",
    email: "info@tshikhuthula.co.za"
};
---

<header 
  id="main-header" 
  class={`fixed top-0 left-0 w-full z-[9999] font-lato transition-all duration-300 ${currentPage !== 'home' ? 'nav-sub-page nav-scrolled' : ''}`}
  data-page-type={currentPage === 'home' ? 'home' : 'sub'}
>

  <!-- Main Navigation Area -->
  <div id="nav-outer" class="relative w-full flex justify-center z-[80] transition-all duration-300 border-b border-white/10 bg-transparent">
      <div id="nav-inner" class="w-full relative transition-all duration-300 max-w-7xl mx-auto">
          <div id="nav-pill" class="flex items-center justify-between h-[90px] relative z-50 overflow-visible transition-all duration-300 px-6 lg:px-8 w-full">
        
        <!-- Mobile Menu Toggle (Left) -->
        <button
          id="mobile-menu-toggle"
          class="md:hidden w-10 h-10 flex items-center justify-center rounded-lg hover:bg-white/10 transition-colors"
          aria-label="Open Menu"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>

        <!-- Left Desktop Navigation -->
        <nav class="hidden md:flex items-center justify-start gap-6 h-full flex-1 pr-10">
          {menuItems.filter((item) => item.key !== 'enrol' && item.key !== 'home').map((item) => (
            <div class="relative group h-full flex items-center">
              <a
                href={item.href}
                class={`nav-link text-[14px] font-bold transition-all flex items-center gap-2 font-lato whitespace-nowrap ${currentPage === item.key ? 'active-link' : 'text-white/90 hover:text-white'}`}
              >
                {item.title}
                {item.children && (
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-[14px] h-[14px] mt-[1px] text-white/70 group-hover:rotate-180 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" />
                  </svg>
                )}
              </a>

              {item.children && (
                <div class="absolute top-full left-0 w-56 bg-white/95 backdrop-blur-md border border-t-0 border-slate-200 shadow-2xl rounded-b-xl py-2 opacity-0 invisible translate-y-2 group-hover:opacity-100 group-hover:visible group-hover:translate-y-0 transition-all duration-300 submenu-dropdown">
                  {item.children.map((child) => (
                    <div class="submenu-link-wrapper px-4 py-1">
                       <a
                        href={child.href}
                        class="block px-4 py-2 text-[13px] font-bold text-slate-600 hover:text-amber-700 transition-all font-lato submenu-link"
                      >
                        {child.title}
                      </a>
                    </div>
                  ))}
                </div>
              )}
            </div>
          ))}
        </nav>

        <!-- Center Logo -->
        <div id="nav-logo-container" class="hidden md:flex items-center justify-center shrink-0 z-[100] transition-all duration-500 ease-[cubic-bezier(0.22,1,0.36,1)] h-[80px] w-[80px] bg-white rounded-full p-1 shadow-[0_4px_15px_rgba(0,0,0,0.1)] border border-slate-100">
          <a href="/" class="flex items-center justify-center h-full w-full">
            <img src="/assets/images/logo5.png" alt="School Logo" class="h-full w-auto object-contain transition-all duration-500" />
          </a>
        </div>

        <!-- Mobile Logo (Center) -->
        <a href="/" class="md:hidden absolute left-1/2 top-1/2 transform -translate-x-1/2 -translate-y-1/2 flex flex-col items-center justify-center gap-1 transition-transform active:scale-95 h-[90px]">
          <div class="h-[75px] w-[75px] bg-white rounded-full p-2 shadow-sm flex items-center justify-center">
            <img src="/assets/images/logo5.png" alt="School Logo" class="h-full w-auto object-contain" />
          </div>
        </a>

        <!-- Right Apply Now Button -->
        <div class="hidden md:flex items-center justify-end h-full flex-1 pl-10">
          <div class="flex items-center shrink-0">
            {menuItems.filter((item) => item.key === 'enrol').map((item) => (
              <a
                href={item.href}
                class="nav-enrol-btn text-[14px] font-bold font-lato whitespace-nowrap"
              >Enrol Now</a>
            ))}
          </div>
        </div>

        <!-- Spacer for Mobile Right -->
        <div class="md:hidden w-10 h-10 mr-6"></div>
      </div>
    </div>
  </div>

  <!-- Mobile Navigation Overlay -->
  <div id="mobile-nav" class="fixed inset-0 z-[150] invisible">
    <div id="mobile-nav-overlay" class="absolute inset-0 bg-slate-900/80 backdrop-blur-sm opacity-0 transition-opacity duration-300"></div>
    <div
      id="mobile-nav-drawer"
      class="absolute top-0 left-0 h-full w-[70vw] bg-white/90 backdrop-blur-[28px] shadow-[20px_0_50px_rgba(0,0,0,0.15)] -translate-x-full transition-transform duration-500 ease-out flex flex-col rounded-r-[50px] border-r border-black/[0.06]"
    >
      <div class="px-4 flex items-center justify-end relative mb-4" style="height: 80px;">
        <a href="/" class="absolute left-1/2 -translate-x-1/2 flex items-center justify-center" style="width: 60px; height: 60px;">
          <div class="bg-white rounded-full shadow-[0_4px_10px_rgba(0,0,0,0.2)] flex items-center justify-center" style="width: 60px; height: 60px; padding: 4px;">
            <img src="/assets/images/logo5.png" alt="Logo" style="width: 52px; height: 52px; object-fit: contain; display: block;" />
          </div>
        </a>
        <button id="mobile-menu-close" class="w-14 h-14 flex items-center justify-center rounded-full bg-slate-100 text-slate-600 hover:bg-slate-200 hover:rotate-90 transition-all duration-300 shadow-sm border border-black/10">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 font-bold" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

      <!-- Root Menu: each item is a flex-grow cell filling equal height -->
      <div id="mobile-menu-content" style="flex: 1; min-height: 0; display: flex; flex-direction: column; overflow: hidden;">
        <div id="menu-root" style="flex: 1; display: flex; flex-direction: column;">
          {menuItems.map((item, idx) => (
            <div class="mobile-nav-cell" style={`flex: 1; display: flex; flex-direction: column; ${idx < menuItems.length - 1 ? 'border-bottom: 1px solid rgba(0,0,0,0.08);' : ''}`}>
              {item.children ? (
                <button
                  data-submenu-id={`submenu-${item.key}`}
                  class="menu-trigger mobile-nav-btn"
                >
                  <span class="mobile-nav-icon" set:html={item.icon} />
                  <span class="mobile-nav-label">{item.title}</span>
                  <svg xmlns="http://www.w3.org/2000/svg" class="mobile-nav-chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
                  </svg>
                </button>
              ) : (
                <a
                  href={item.href}
                  class="mobile-nav-btn"
                >
                  <span class="mobile-nav-icon" set:html={item.icon} />
                  <span class="mobile-nav-label">{item.title}</span>
                </a>
              )}
            </div>
          ))}
        </div>

        <!-- Submenus (Hidden by default, slide in) -->
        {menuItems.filter(i => i.children).map(item => (
          <div id={`submenu-${item.key}`} class="hidden absolute inset-0 bg-white/90 backdrop-blur-[28px] rounded-r-[50px] flex flex-col z-10 transition-transform duration-300 shadow-[-10px_0_20px_rgba(0,0,0,0.1)] border-r border-black/[0.06]">
            <div class="px-8 py-8 flex items-center gap-6 border-b border-black/[0.08]">
              <button class="submenu-back w-12 h-12 flex items-center justify-center rounded-full bg-slate-100 text-slate-600 hover:bg-slate-200 transition-all duration-300 border border-black/10 shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7" />
                </svg>
              </button>
              <span class="text-[13px] font-black uppercase tracking-[0.2em] text-slate-700 font-lato">{item.title}</span>
            </div>

            <div style="flex: 1; display: flex; flex-direction: column; overflow: hidden;">
              {item.children?.map((child, cidx) => (
                <a
                  href={child.href}
                  class="submenu-cell-link"
                  style={`flex: 1; display: flex; align-items: center; justify-content: center; ${cidx < (item.children?.length ?? 0) - 1 ? 'border-bottom: 1px solid rgba(0,0,0,0.08);' : ''}`}
                >
                  <span class="text-[11px] font-black uppercase tracking-widest text-slate-600 font-lato text-center px-4">{child.title}</span>
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</header>

<style>
  /* Explicit fallback backgrounds — some mobile webviews don't support
     the color-mix()-based alpha utilities (bg-white/90, bg-slate-900/80),
     which left the drawer/overlay fully transparent. */
  #mobile-nav-overlay {
    background-color: rgba(15, 23, 42, 0.8);
  }
  #mobile-nav-drawer,
  #mobile-nav [id^="submenu-"] {
    background-color: rgba(255, 255, 255, 0.97);
  }

  /* HARD FALLBACK FOR DESKTOP VISIBILITY */
  @media (min-width: 768px) {
    #mobile-menu-toggle,
    .md\:hidden {
      display: none !important;
    }
    nav.hidden.md\:flex,
    div.hidden.md\:flex {
      display: flex !important;
    }
  }

  /* SMOOTH TRANSITIONS */
  #main-header, #main-header nav a, #main-header .logo-name, #main-header .logo-tagline {
    transition: all 0.5s cubic-bezier(0.22, 1, 0.36, 1);
  }
  
  /* INITIAL STATE (Dark Translucent) */
  #main-header:not(.nav-scrolled) #nav-pill {
    background-color: transparent !important;
  }
  
  /* SCROLLED STATE (Light Background, Dark Text) */
  #main-header.nav-scrolled #nav-outer {
    background: rgba(255, 255, 255, 0.95) !important;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
    border-bottom-color: transparent !important;
  }
  #main-header.nav-scrolled #nav-pill {
    background: transparent !important;
    box-shadow: none !important;
  }

  #main-header.nav-scrolled .nav-link { color: #334155 !important; }
  #main-header.nav-scrolled .nav-link:hover { color: #d97706 !important; }
  #main-header.nav-scrolled .active-link { color: #d97706 !important; }
  #main-header.nav-scrolled .active-link::after { background: #d97706 !important; }
  #main-header.nav-scrolled .nav-link svg { color: #64748b !important; }
  #main-header.nav-scrolled #mobile-menu-toggle svg { color: #334155 !important; }
  #main-header.nav-scrolled #mobile-menu-toggle { background: rgba(0,0,0,0.05); }
  
  /* Shrinking Logo on Scroll */
  #nav-logo-container.logo-scrolled {
    height: 70px !important;
    width: 70px !important;
    padding: 0 !important;
    background: transparent !important;
    border-color: transparent !important;
    box-shadow: none !important;
    transform: translateY(0) !important;
  }

  #main-header.nav-sub-page .submenu-dropdown {
    background: #ffffff !important;
    border: 1px solid #f1f5f9;
    box-shadow: 0 20px 50px rgba(0,0,0,0.1);
  }
  #main-header.nav-sub-page .submenu-link { color: #64748b !important; }
  #main-header.nav-sub-page .submenu-link:hover { color: #961107 !important; background: #f8fafc; }

  /* LINKS & ACTIVE STATES */
  .nav-link {
    position: relative;
    padding: 0.5rem 0;
  }
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 1px;
    background: #d97706; /* Amber color */
    transition: width 0.3s ease;
  }
  .nav-link:hover::after, .active-link::after { width: 100%; }
  .active-link { color: #ffffff !important; }

  /* Enrol Now — maroon CTA */
  .nav-enrol-btn {
    display: none;
    align-items: center;
    justify-content: center;
    padding: 0.8rem 2rem;
    border-radius: 999px;
    background: #961107; /* Maroon */
    color: #fff !important;
    transition: background 0.25s ease, transform 0.25s ease;
  }
  @media (min-width: 768px) {
    .nav-enrol-btn {
      display: inline-flex;
    }
  }
  .nav-enrol-btn:hover {
    background: #7a0e05;
    transform: translateY(-2px);
  }

  /* SUBMENU ENHANCEMENTS */
  .submenu-dropdown {
    background: #ffffff !important;
    border: 1px solid #f1f5f9 !important;
    border-radius: 12px !important;
    box-shadow: 0 20px 50px rgba(0,0,0,0.1) !important;
    padding: 2rem 0 !important;
  }
  
  /* Submenu links: slate text */
  .submenu-link {
    color: #64748b !important;
    padding: 0.75rem 0 !important;
  }
  
  /* Submenu links hover: light bg, maroon text */
  .submenu-link:hover {
      background-color: #f8fafc !important; 
      color: #961107 !important; 
  }
  
  /* Gradient shade on megamenu wrapper */
  .submenu-dropdown .submenu-link-wrapper {
      background: linear-gradient(180deg, rgba(34, 139, 34, 0.1) 0%, rgba(0, 100, 0, 0.05) 100%);
      border-radius: 4px;
      transition: all 0.3s ease;
  }
  
  /* Hover effect on wrapper - full height coverage */
  .submenu-dropdown .submenu-link-wrapper:hover {
      background: linear-gradient(180deg, #cb8f24 0%, #cb8f24 100%) !important;
  }
  
  .submenu-dropdown .submenu-link-wrapper:hover .submenu-link {
      color: #961107 !important;
  }
  
  /* MOBILE TOGGLE */
  #main-header:not(.nav-scrolled) #mobile-menu-toggle {
    background: rgba(255,255,255,0.1);
    color: #961107;
  }
  #main-header:not(.nav-scrolled) #mobile-menu-toggle svg { color: #961107; }

  #main-header.nav-scrolled #mobile-menu-toggle {
    background: rgba(0,0,0,0.05);
    color: #961107;
  }
  #main-header.nav-scrolled #mobile-menu-toggle svg { color: #961107; }

  /* ==============================
     MOBILE NAV FULL-HEIGHT CELLS
     ============================== */

  /* Each cell fills its share of drawer height */
  .mobile-nav-cell {
    position: relative;
    display: flex;
    flex-direction: column;
  }

  /* Button / link fills the full cell */
  .mobile-nav-btn {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 10px;
    width: 100%;
    position: relative;
    background: transparent;
    border: none;
    cursor: pointer;
    color: #475569;
    text-decoration: none;
    transition: background 0.25s ease;
    padding: 0 1rem;
  }
  .mobile-nav-btn:hover,
  .mobile-nav-btn:active {
    background: rgba(0, 0, 0, 0.04);
  }

  /* Icon above text */
  .mobile-nav-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.75;
    transform: scale(1.3);
    color: #961107;
  }
  .mobile-nav-icon svg {
    width: 24px;
    height: 24px;
    stroke: currentColor;
  }

  /* Label text */
  .mobile-nav-label {
    font-family: 'Lato', sans-serif;
    font-size: 10px;
    font-weight: 900;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #475569;
    text-align: center;
    line-height: 1.2;
    white-space: nowrap;
  }

  /* Chevron for "Our School" — absolute top-right */
  .mobile-nav-chevron {
    position: absolute;
    top: 50%;
    right: 1.25rem;
    transform: translateY(-50%);
    width: 18px;
    height: 18px;
    color: #94a3b8;
    stroke: currentColor;
  }

  /* Submenu full-height cell links */
  .submenu-cell-link {
    text-decoration: none;
    transition: background 0.25s ease;
  }
  .submenu-cell-link:hover {
    background: rgba(0, 0, 0, 0.04);
  }
  .submenu-cell-link span {
    font-family: 'Lato', sans-serif;
    font-size: 11px;
    font-weight: 900;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #475569;
  }
  .submenu-cell-link:hover span {
    color: #961107;
  }

</style>

<script>
  function initMobileMenu() {
    const mobileNav = document.getElementById('mobile-nav');
    const toggle = document.getElementById('mobile-menu-toggle');
    const close = document.getElementById('mobile-menu-close');
    const overlay = document.getElementById('mobile-nav-overlay');
    const drawer = document.getElementById('mobile-nav-drawer');
    const triggers = document.querySelectorAll('.menu-trigger');
    const backButtons = document.querySelectorAll('.submenu-back');

    if (!mobileNav || !toggle || !close || !overlay || !drawer) return;

    function openMenu() {
      mobileNav!.classList.remove('invisible');
      overlay!.classList.add('opacity-100');
      drawer!.classList.add('translate-x-0');
      drawer!.classList.remove('-translate-x-full');
      document.body.style.overflow = 'hidden';
    }

    function closeMenu() {
      overlay!.classList.remove('opacity-100');
      drawer!.classList.add('-translate-x-full');
      drawer!.classList.remove('translate-x-0');
      setTimeout(() => {
        mobileNav!.classList.add('invisible');
        // Reset submenus on close
        document.querySelectorAll('[id^="submenu-"]').forEach(el => el.classList.add('hidden'));
      }, 300);
      document.body.style.overflow = '';
    }

    toggle.onclick = openMenu;
    close.onclick = closeMenu;
    overlay.onclick = closeMenu;

    triggers.forEach(trigger => {
        trigger.addEventListener('click', () => {
            const submenuId = (trigger as HTMLElement).dataset.submenuId;
            const submenu = document.getElementById(submenuId!);
            if (submenu) submenu.classList.remove('hidden');
        });
    });

    backButtons.forEach(btn => {
        btn.addEventListener('click', () => {
            const submenu = btn.closest('[id^="submenu-"]');
            if (submenu) submenu.classList.add('hidden');
        });
    });
  }

  // Ensure menu runs after Astro page transitions
  initMobileMenu();
  document.addEventListener('astro:after-swap', initMobileMenu);

  // Smooth transitions
  function initStickyNav() {
    const header = document.getElementById('main-header');
    const navOuter = document.getElementById('nav-outer');
    const navInner = document.getElementById('nav-inner');
    const navPill  = document.getElementById('nav-pill');
    const navLogo  = document.getElementById('nav-logo-container');
    if (!header || !navOuter || !navInner || !navPill) return;

    // Check if we're on home page
    const isHomePage = header.dataset.pageType === 'home';

    const threshold = window.innerHeight * 0.05;

    function setScrolledState() {
      header!.style.top = '0';
      header!.classList.add('nav-scrolled');
      navOuter!.classList.remove('px-4', 'sm:px-6');
      navOuter!.style.padding = '0';
      navInner!.style.maxWidth = '100%';
      navPill!.classList.remove('rounded-xl');
      navPill!.style.borderRadius = '0';
      if (navLogo) navLogo.classList.add('logo-scrolled');
    }

    function setAtTopState() {
      header!.style.top = '0';
      header!.classList.remove('nav-scrolled');
      navOuter!.style.padding = '';
      navInner!.style.maxWidth = '';
      navPill!.classList.add('rounded-xl');
      navPill!.style.borderRadius = '';
      if (navLogo) navLogo.classList.remove('logo-scrolled');
    }

    function onScroll() {
      if (isHomePage) {
        if (window.scrollY > threshold) {
          setScrolledState();
        } else {
          setAtTopState();
        }
      } else {
        // Sub-pages: always full-width scrolled style
        setScrolledState();
      }
    }
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }
  initStickyNav();
  document.addEventListener('astro:after-swap', initStickyNav);
</script>
