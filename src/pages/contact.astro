---

<Layout title="Contact Us - Tshikhuthula Secondary School" currentPage="contact" noNavbarPadding={true} showMainNav={true}>
    <SecondaryNav currentPage="contact" />

    <!-- ── Header ── -->
    <header class="contact-header ws-reveal">
        <div class="contact-header-bg"></div>
        <div class="contact-header-content">
            <div class="inline-flex items-center gap-3 px-5 py-2 rounded-full border border-gold-500/30 bg-gold-500/10 backdrop-blur-md mb-6">
                <span class="text-[10px] font-black uppercase tracking-[0.3em] text-gold-400">Get in Touch</span>
            </div>
            <h1 class="text-5xl md:text-7xl font-heading text-white font-display drop-shadow-lg tracking-tight mb-6">
                Contact <span class="text-transparent bg-clip-text bg-gradient-to-r from-gold-400 to-gold-600">Our School</span>
            </h1>
            <p class="text-slate-300 max-w-3xl mx-auto page-header-tagline">
                We're here to help. Reach out to us for any enquiries, admissions information, or general support.
            </p>
        </div>
    </header>

    <!-- ── Contact Info Cards ── -->
    <section class="contact-cards-section">
        <div class="max-w-7xl mx-auto">
            <div class="contact-cards-grid">
                {contactCards.map((card, i) => (
                    <div class={`contact-card ws-reveal delay-${i + 1}`}>
                        <div class="contact-card-icon" set:html={card.icon} />
                        <h3 class="contact-card-title">{card.title}</h3>
                        <p class="contact-card-detail">{card.detail1}</p>
                        <p class="contact-card-detail secondary">{card.detail2}</p>
                        <div class="contact-card-rule"></div>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- ── Departmental Contacts ── -->
    <section class="dept-section bg-slate-50">
        <div class="max-w-7xl mx-auto">
            <div class="ab-section-label mb-14 ws-reveal text-center items-center">
                <span class="ab-label-eyebrow text-maroon-800">School Directory</span>
                <h2 class="ab-label-heading">Departmental Contacts</h2>
                <div class="ab-label-rule mx-auto"></div>
            </div>
            <div class="dept-grid">
                {departments.map((dept, i) => (
                    <div class={`dept-card ws-reveal delay-${i + 1}`}>
                        <div class="dept-card-icon" set:html={dept.icon} />
                        <div class="dept-card-body">
                            <h3 class="dept-card-title">{dept.title}</h3>
                            <p class="dept-card-head">{dept.head}</p>
                            <p class="dept-card-role">{dept.role}</p>
                            <p class="dept-card-email">{dept.email}</p>
                            <span class="dept-card-ext">Ext. {dept.ext}</span>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- ── Contact Form ── -->
    <section class="form-section">
        <div class="max-w-7xl mx-auto">
            <div class="form-layout">
                <!-- Left: Info -->
                <div class="form-info ws-reveal">
                    <div class="ab-section-label mb-8 items-start text-left">
                        <span class="ab-label-eyebrow text-maroon-800">Send a Message</span>
                        <h2 class="ab-label-heading" style="font-size: clamp(2rem, 4vw, 3rem);">We'd love to<br/>hear from you</h2>
                        <div class="ab-label-rule"></div>
                    </div>
                    <p class="form-info-text">
                        Fill in the form and one of our team members will get back to you within one business day. For urgent matters please call us directly.
                    </p>
                    <div class="form-info-items">
                        <div class="form-info-item">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.11 11.9a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.06 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                            <span>(015) 123 4567</span>
                        </div>
                        <div class="form-info-item">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" points="22,6 12,13 2,6"/></svg>
                            <span>info@tshikhuthula.co.za</span>
                        </div>
                        <div class="form-info-item">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"/></svg>
                            <span>Limpopo, South Africa</span>
                        </div>
                    </div>
                </div>

                <!-- Right: Form -->
                <div class="form-card ws-reveal delay-2">
                    <!-- Tabs -->
                    <div class="form-tabs" role="tablist">
                        <button class="form-tab active" data-tab="general">General</button>
                        <button class="form-tab" data-tab="admissions">Admissions</button>
                        <button class="form-tab" data-tab="feedback">Feedback</button>
                        <button class="form-tab" data-tab="complaint">Complaint</button>
                    </div>

                    <form id="modernContactForm" class="contact-form" data-access-key={WEB3FORMS_ACCESS_KEY} novalidate>
                        <div class="form-row">
                            <div class="form-group">
                                <label for="name">Full Name *</label>
                                <input type="text" id="name" name="name" placeholder="Your full name" autocomplete="name" required />
                            </div>
                            <div class="form-group">
                                <label for="email">Email Address *</label>
                                <input type="email" id="email" name="email" placeholder="your@email.com" autocomplete="email" required />
                            </div>
                        </div>
                        <div class="form-group">
                            <label for="subject">Subject *</label>
                            <input type="text" id="subject" name="subject" placeholder="How can we help?" required />
                        </div>
                        <div class="form-group">
                            <label for="message">Message *</label>
                            <textarea id="message" name="message" rows="5" placeholder="Please provide detailed information..." required></textarea>
                        </div>
                        <!-- Honeypot — hidden from users; bots that fill it are silently dropped. -->
                        <input type="text" name="botcheck" tabindex="-1" autocomplete="off" aria-hidden="true" style="position:absolute;left:-9999px;width:1px;height:1px;overflow:hidden;" />
                        <p id="contactFormStatus" role="status" aria-live="polite" style="margin:0 0 0.5rem;"></p>
                        <button type="submit" class="form-submit">
                            Send Message
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><line x1="22" y1="2" x2="11" y2="13" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/><polygon stroke-linecap="round" stroke-linejoin="round" stroke-width="2" points="22 2 15 22 11 13 2 9 22 2"/></svg>
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </section>

    <!-- ── Emergency Contacts ── -->
    <section class="emergency-section ws-reveal">
        <div class="emergency-bg"></div>
        <div class="max-w-7xl mx-auto" style="position: relative; z-index: 2;">
            <div class="ab-section-label mb-12 text-center items-center">
                <span class="ab-label-eyebrow" style="color: #cb8f24;">Critical Information</span>
                <h2 class="ab-label-heading" style="color: #fff;">Emergency Contacts</h2>
                <div class="ab-label-rule mx-auto"></div>
            </div>
            <div class="emergency-grid">
                <div class="emergency-card">
                    <div class="emergency-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 3h2l.4 2M7 13h10l4-8H5.4"/><circle cx="7" cy="16" r="1" stroke-width="1.5"/><circle cx="20" cy="16" r="1" stroke-width="1.5"/></svg>
                    </div>
                    <h3>Medical</h3>
                    <p>On-campus: <strong>Ext. 911</strong></p>
                    <p>Ambulance: <strong>10177</strong></p>
                </div>
                <div class="emergency-card">
                    <div class="emergency-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                    </div>
                    <h3>Security</h3>
                    <p>Office: <strong>Ext. 301</strong></p>
                    <p>Police: <strong>10111</strong></p>
                </div>
                <div class="emergency-card">
                    <div class="emergency-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><polygon stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                    </div>
                    <h3>Fire</h3>
                    <p>Department: <strong>10177</strong></p>
                    <p>Warden: <strong>Ext. 302</strong></p>
                </div>
                <div class="emergency-card">
                    <div class="emergency-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M18 8h1a4 4 0 0 1 0 8h-1"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/><line x1="6" y1="1" x2="6" y2="4" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"/><line x1="10" y1="1" x2="10" y2="4" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"/><line x1="14" y1="1" x2="14" y2="4" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"/></svg>
                    </div>
                    <h3>Crisis</h3>
                    <p>Childline: <strong>08000 55555</strong></p>
                    <p>Lifeline: <strong>0861 322 322</strong></p>
                </div>
            </div>
        </div>
    </section>
</Layout>

<script>
    function initContact() {
        // Tabs
        const tabs = document.querySelectorAll('.form-tab');
        const subjectInput = document.getElementById('subject') as HTMLInputElement;

        tabs.forEach(tab => {
            tab.addEventListener('click', () => {
                tabs.forEach(t => t.classList.remove('active'));
                tab.classList.add('active');
                const tabName = tab.getAttribute('data-tab');
                if (subjectInput && tabName !== 'general') {
                    subjectInput.value = tabName!.charAt(0).toUpperCase() + tabName!.slice(1) + ' Inquiry';
                } else if (subjectInput) {
                    subjectInput.value = '';
                }
            });
        });

        // Form submit → Web3Forms (no backend, pure static).
        const form = document.getElementById('modernContactForm') as HTMLFormElement | null;
        const status = document.getElementById('contactFormStatus') as HTMLElement | null;
        if (form && form.dataset.wired !== '1') {
            form.dataset.wired = '1';
            form.addEventListener('submit', async (e) => {
                e.preventDefault();
                if (status) { status.textContent = ''; status.style.color = ''; }

                const data = new FormData(form);
                // Honeypot — if a bot filled this, silently pretend success.
                if (String(data.get('botcheck') ?? '').trim()) { form.reset(); return; }

                const required = ['name', 'email', 'subject', 'message'];
                for (const field of required) {
                    if (!String(data.get(field) ?? '').trim()) {
                        if (status) { status.style.color = '#b91c1c'; status.textContent = 'Please complete all required fields.'; }
                        return;
                    }
                }

                const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;
                const originalHTML = submitBtn?.innerHTML ?? '';
                if (submitBtn) { submitBtn.disabled = true; submitBtn.textContent = 'Sending…'; }

                try {
                    const resp = await fetch('https://api.web3forms.com/submit', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
                        body: JSON.stringify({
                            access_key: form.dataset.accessKey ?? '',
                            from_name: String(data.get('name') ?? ''),
                            subject: `[Contact] ${String(data.get('subject') ?? '')}`,
                            name: String(data.get('name') ?? ''),
                            email: String(data.get('email') ?? ''),
                            message: String(data.get('message') ?? ''),
                        }),
                    });
                    const result = await resp.json().catch(() => ({})) as { success?: boolean };
                    if (resp.ok && result.success) {
                        form.reset();
                        if (status) { status.style.color = '#15803d'; status.textContent = 'Thank you! Your message has been sent.'; }
                    } else if (status) {
                        status.style.color = '#b91c1c';
                        status.textContent = 'Sorry, we couldn’t send your message. Please email us directly at info@tshikuthula.co.za.';
                    }
                } catch {
                    if (status) { status.style.color = '#b91c1c'; status.textContent = 'Network error. Please try again, or email info@tshikuthula.co.za.'; }
                } finally {
                    if (submitBtn) { submitBtn.disabled = false; submitBtn.innerHTML = originalHTML; }
                }
            });
        }
    }

    // Scroll reveal
    function initReveal() {
        const observer = new IntersectionObserver(
            (entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('reveal-active');
                        observer.unobserve(entry.target);
                    }
                });
            },
            { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
        );
        document.querySelectorAll('.ws-reveal').forEach(el => observer.observe(el));
    }

    initContact();
    initReveal();
    document.addEventListener('astro:after-swap', initContact);
    document.addEventListener('astro:after-swap', initReveal);
</script>
