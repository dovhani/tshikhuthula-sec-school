---
import Layout from '../layouts/Layout.astro';
import '../styles/home.css';

const currentYear = new Date().getFullYear();
const enrolmentYear = currentYear + 1;
const yearsOfExcellence = currentYear - 1967;

const stats = [
    { label: "Students Enrolled", value: "615", prefix: "", suffix: "" },
    { label: "Qualified Teachers", value: "23", prefix: "", suffix: "" },
    { label: "Pass Rate", value: "98", prefix: "", suffix: "%" },
    { label: "Years of Excellence", value: yearsOfExcellence.toString(), prefix: "", suffix: "" }
];

const highlights = [
    { title: "Upcoming Events", description: "Check our calendar for parent-teacher meetings, sports days, and cultural events.", btnText: "View Calendar", href: "/calendar" },
    { title: "Recent Achievements", description: "Our students excel in academics, sports, and cultural activities at district level.", btnText: "View Achievements", href: "/gallery/achievements" },
    { title: "Enrolment Open", description: `Applications for the ${enrolmentYear} academic year are now open. Limited spaces available.`, btnText: "Apply Now", href: "/enrolment" }
];

const news = [
    { date: "Dec 15, 2023", title: "Annual Prize Giving Ceremony", description: "Congratulations to all participants in our annual inter-house sports competition.", href: "/calendar" },
    { date: "Dec 10, 2023", title: "Holiday Break Schedule", description: "School will close on December 15th and reopen on January 8th, 2024.", href: "/calendar" },
    { date: "Dec 5, 2023", title: "New Library Resources", description: "Our library has been upgraded with new books and digital learning resources.", href: "/about" }
];
---

<Layout title="Home - Tshikhuthula Secondary School" currentPage="home">
    <!-- ════════════════════════════════════════
         HERO SECTION – Cinematic Slider
         ════════════════════════════════════════ -->
    <section id="hero" class="hero-section">

        <!-- ── Background Slider ── -->
        <div class="hero-bg-layer">
            <!-- Dark overlay for readability -->
            <div class="hero-overlay-dark"></div>
            <!-- Gradient vignette top/bottom -->
            <div class="hero-overlay-gradient"></div>

            <div class="hero-slider">
                <div class="slide active-slide" style="background-image: url('/assets/images/backgrounds/heritagebg.jpg')"></div>
            </div>
        </div>

        <!-- ── Main Hero Content ── -->
        <div class="hero-content-wrapper">
            <div class="hero-content">

                <!-- Heading: Welcome to · TSHIKHUTHULA · Secondary School (centered lockup) -->
                <h1 class="hero-heading">
                    <span class="hero-reveal-1 hero-eyebrow">Welcome to</span>
                    <span class="hero-reveal-2 hero-school-name">Tshikhuthula</span>
                    <div class="hero-divider"></div>
                    <span class="hero-reveal-3 hero-secondary-label">Secondary School</span>
                </h1>

                <!-- Tagline + Buttons -->
                <div class="hero-bottom-block hero-subtitle-anim">
                    <p class="hero-tagline">
                        Nurturing Minds &nbsp;·&nbsp; Shaping Leaders &nbsp;·&nbsp; Building Excellence
                    </p>
                    <div class="hero-buttons-anim hero-ctas">
                        <a href="/enrolment" class="hero-btn hero-btn--primary">Enrol Now</a>
                        <a href="/about" class="hero-btn hero-btn--secondary">Discover</a>
                    </div>
                </div>

            </div>
        </div>

        <!-- ── Stats Bar ── (pinned to bottom of hero, always visible) -->
        <div id="welcome-header" class="hero-stats-bar">
            {stats.map((stat, i) => (
                <div class="hero-stat-card">
                    <div class="hero-stat-icon">
                        {i === 0 && <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" /></svg>}
                        {i === 1 && <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" /></svg>}
                        {i === 2 && <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>}
                        {i === 3 && <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-7.714 2.143L11 21l-2.286-6.857L1 12l7.714-2.143L11 3z" /></svg>}
                    </div>
                    <div class="hero-stat-info">
                        <div class="hero-stat-number stat-number"
                             data-target={stat.value}
                             data-suffix={stat.suffix}>
                            {stat.prefix}0{stat.suffix}
                        </div>
                        <div class="hero-stat-label">{stat.label}</div>
                    </div>
                    <div class="hero-stat-divider"></div>
                </div>
            ))}
        </div>

        <!-- ── Scroll indicator ── -->
        <a href="#welcome-header" class="hero-scroll-btn" aria-label="Scroll down">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M19 9l-7 7-7-7" />
            </svg>
        </a>

    </section>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-20">

        <!-- ══════════════════════════════════════════════
             WELCOME – Full Rich Section
             ══════════════════════════════════════════════ -->

        <!-- Section label -->
        <section class="ws-section-label">
            <p class="ws-label-eyebrow">Est. 1967 · Limpopo, South Africa</p>
            <h2 class="ws-label-heading">Welcome to Tshikhuthula</h2>
            <div class="ws-label-rule"></div>
        </section>

        <!-- Mission banner -->
        <div class="ws-mission-card">
            <div class="ws-mission-badge">
                <span>🎯</span> Our Mission
            </div>
            <p class="ws-mission-statement">
                To equip every learner with knowledge, values, and resilience — transforming raw potential 
                into purposeful achievement for a changing South Africa and a global future.
            </p>
        </div>

        <!-- Principal + Story two-column -->
        <section class="ws-main-grid">

            <!-- LEFT: Principal image card -->
            <div class="ws-principal-col ws-reveal">
                <div class="ws-principal-frame">

                    <!-- Floating accent badge -->
                    <div class="ws-badge">
                        <svg class="ws-badge-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                  d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
                        </svg>
                        <span>{yearsOfExcellence} Years of Excellence</span>
                    </div>

                    <!-- Photo -->
                    <div class="ws-principal-photo-wrap">
                        <img
                            src="/assets/images/staff/principal.jpg"
                            alt="Mr Mulaudzi S.S. — Principal"
                            class="ws-principal-photo"
                        />
                        <!-- Subtle color overlay on hover -->
                        <div class="ws-photo-sheen"></div>
                    </div>

                    <!-- Identity card -->
                    <div class="ws-principal-card">
                        <div class="ws-principal-card-inner">
                            <p class="ws-principal-name">Mr Mulaudzi S.S.</p>
                            <div class="ws-principal-divider">
                                <span class="ws-principal-rule"></span>
                                <span class="ws-principal-role">Principal · Tshikhuthula Secondary</span>
                            </div>
                            <p class="ws-principal-years">Leading with vision since 2023</p>
                        </div>
                        <!-- Decorative maroon bar -->
                        <div class="ws-principal-card-bar"></div>
                    </div>

                    <!-- Background geometric accent -->
                    <div class="ws-geo-accent"></div>
                </div>
            </div>

            <!-- RIGHT: Story + values -->
            <div class="ws-story-col">

                <!-- Eyebrow + heading -->
                <div class="ws-story-header ws-reveal">
                    <span class="ws-eyebrow">Since 1967</span>
                    <div class="ws-story-heading-stack">
                        <h2 class="ws-story-heading">Inspiring Minds,</h2>
                        <h2 class="ws-story-heading ws-story-heading--alt">Shaping Exceptional Futures</h2>
                    </div>
                </div>

                <!-- Principal's spoken word quote -->
                <div class="ws-quote-wrap ws-reveal">
                    <blockquote class="ws-quote">
                        <span class="ws-quote-mark">&ldquo;</span>
                        <p class="ws-quote-body">
                            Every learner who walks through these gates carries within them a story 
                            that deserves to be heard, celebrated, and elevated. At Tshikhuthula, 
                            we do not just teach — we ignite. We build character alongside curriculum, 
                            and courage alongside academics. This school is not merely a place of learning;
                            it is a forge of future leaders.
                        </p>
                        <cite class="ws-quote-cite">
                            <span class="ws-quote-name">— Mr Mulaudzi S.S.</span>
                            <span class="ws-quote-role">Principal</span>
                        </cite>
                    </blockquote>
                </div>

                <!-- Value pillars -->
                <div class="ws-pillars ws-reveal">
                    <div class="ws-pillar">
                        <div class="ws-pillar-icon-wrap">
                            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                      d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                            </svg>
                        </div>
                        <div>
                            <h3 class="ws-pillar-title">Academic Excellence</h3>
                            <p class="ws-pillar-desc">Rigorous, future-focused curriculum equipping learners for university and beyond.</p>
                        </div>
                    </div>

                    <div class="ws-pillar">
                        <div class="ws-pillar-icon-wrap">
                            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                      d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
                            </svg>
                        </div>
                        <div>
                            <h3 class="ws-pillar-title">Community & Character</h3>
                            <p class="ws-pillar-desc">Cultivating integrity, empathy, and ubuntu as the bedrock of every graduate.</p>
                        </div>
                    </div>

                    <div class="ws-pillar">
                        <div class="ws-pillar-icon-wrap">
                            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                      d="M13 10V3L4 14h7v7l9-11h-7z" />
                            </svg>
                        </div>
                        <div>
                            <h3 class="ws-pillar-title">Innovation & Sport</h3>
                            <p class="ws-pillar-desc">Arts, athletics, and technology programs to develop every dimension of the whole learner.</p>
                        </div>
                    </div>
                </div>

                <!-- CTA -->
                <div class="ws-cta ws-reveal">
                    <a href="/about" class="ws-cta-link">
                        Discover Our Story
                        <span class="ws-cta-arrow">
                            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                            </svg>
                        </span>
                    </a>
                    <a href="/enrolment" class="ws-cta-secondary">
                        Apply Now &rarr;
                    </a>
                </div>
            </div>
        </section>

        <!-- ══════════════════════════════════════════════
             SCHOOL HIGHLIGHTS – Premium Section
             ══════════════════════════════════════════════ -->
        <div class="sh-section">

            <!-- Section label (same pattern as welcome) -->
            <div class="sh-section-label sh-reveal">
                <span class="sh-eyebrow">In Pursuit of Glory</span>
                <h2 class="sh-heading">School Highlights</h2>
                <div class="sh-rule"></div>
            </div>

            <!-- Accent banner -->
            <div class="sh-banner sh-reveal">
                <div class="sh-banner-left">
                    <svg class="sh-banner-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                              d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
                    </svg>
                    <span>Highlights</span>
                </div>
                <p class="sh-banner-text">
                    Celebrating the milestones, events, and achievements that define the Tshikhuthula spirit — 
                    a community united by excellence and powered by purpose.
                </p>
            </div>

            <!-- Cards grid -->
            <div class="sh-grid">
                {highlights.map((item, i) => (
                    <div class={`sh-card sh-reveal sh-card--${i + 1}`}>
                        <!-- Number accent -->
                        <div class="sh-card-num">0{i + 1}</div>

                        <!-- Icon panel -->
                        <div class="sh-card-icon-panel">
                            {i === 0 && (
                                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                          d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                </svg>
                            )}
                            {i === 1 && (
                                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                          d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                                </svg>
                            )}
                            {i === 2 && (
                                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                          d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
                                </svg>
                            )}
                        </div>

                        <!-- Content -->
                        <div class="sh-card-body">
                            <h3 class="sh-card-title">{item.title}</h3>
                            <p class="sh-card-desc">{item.description}</p>
                            <a href={item.href} class="sh-card-link">
                                {item.btnText}
                                <span class="sh-card-link-line"></span>
                                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                                </svg>
                            </a>
                        </div>

                        <!-- Bottom maroon/gold bar -->
                        <div class="sh-card-bar"></div>
                    </div>
                ))}
            </div>
        </div>

        <!-- ══════════════════════════════════════════════
             NEWS & ANNOUNCEMENTS – Premium Section
             ══════════════════════════════════════════════ -->
        <section class="sh-news-section">

            <!-- Section label -->
            <div class="sh-section-label sh-reveal">
                <span class="sh-eyebrow">Stay Updated</span>
                <h2 class="sh-heading">News &amp; Announcements</h2>
                <div class="sh-rule"></div>
            </div>

            <!-- Accent banner -->
            <div class="sh-banner sh-reveal">
                <div class="sh-banner-left">
                    <svg class="sh-banner-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                              d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
                    </svg>
                    <span>Latest News</span>
                </div>
                <p class="sh-banner-text">
                    From prize-giving ceremonies to holiday schedules and new resources — 
                    stay close to everything happening at Tshikhuthula.
                </p>
            </div>

            <!-- News cards -->
            <div class="sh-grid">
                {news.map((item, i) => (
                    <div class={`sh-news-card sh-reveal sh-card--${i + 1}`}>
                        <!-- Date chip + icon -->
                        <div class="sh-news-top">
                            <span class="sh-news-date">{item.date}</span>
                            <div class="sh-news-icon-wrap">
                                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                          d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                </svg>
                            </div>
                        </div>

                        <!-- Divider line -->
                        <div class="sh-news-divider"></div>

                        <!-- Content -->
                        <h3 class="sh-news-title">{item.title}</h3>
                        <p class="sh-news-desc">{item.description}</p>

                        <!-- Link -->
                        <div class="sh-news-footer">
                            <a href={item.href} class="sh-news-link">
                                Read Full Story
                                <span class="sh-news-link-rule"></span>
                            </a>
                        </div>

                        <!-- Left accent bar (gradient) -->
                        <div class="sh-news-bar"></div>
                    </div>
                ))}
            </div>
        </section>
    </div>
</Layout>

<style>
  /* ════════════════════════════════════════
     HERO – Structure
     ════════════════════════════════════════ */
  .hero-section {
    position: relative;
    width: 100%;
    height: 100vh;
    height: 100dvh; /* fills actual visible viewport, no gap below */
    min-height: 600px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  /* ── Background layer ── */
  .hero-bg-layer {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .hero-overlay-dark {
    position: absolute;
    inset: 0;
    background: rgba(15, 23, 42, 0.55);
    z-index: 2;
    pointer-events: none;
  }
  .hero-overlay-gradient {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 65% 55% at 50% 38%, rgba(15,23,42,0.55) 0%, transparent 70%),
      linear-gradient(
        to bottom,
        rgba(15,23,42,0.75) 0%,
        transparent 35%,
        transparent 55%,
        rgba(15,23,42,0.80) 100%
      );
    z-index: 3;
    pointer-events: none;
  }
  .hero-slider {
    position: absolute;
    inset: 0;
    z-index: 1;
  }
  .hero-slider .slide {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    opacity: 0;
    transition: opacity 2s ease-in-out;
  }
  .hero-slider .slide.active-slide { opacity: 1; }

  /* ── Content wrapper ── */
  .hero-content-wrapper {
    position: relative;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 1;
    width: 100%;
    padding: 0 clamp(1.5rem, 6vw, 5rem);
    padding-top: calc(5vh + 7.5rem);
    padding-bottom: 8rem; /* extra room so text clears the pinned stats bar */
  }
  .hero-content {
    text-align: center;
    max-width: 64rem;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: clamp(1.25rem, 3vw, 2.25rem);
  }

  /* Heading block: single centered lockup */
  .hero-heading {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
    margin: 0;
    text-align: center;
  }
  /* "Welcome to" — small centered eyebrow */
  .hero-eyebrow {
    display: inline-block;
    font-family: 'Lato', sans-serif;
    font-size: clamp(0.65rem, 1.6vw, 0.85rem);
    font-weight: 700;
    letter-spacing: 0.45em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.75);
    text-shadow: 0 2px 8px rgba(0,0,0,0.45);
  }
  /* Main school name */
  .hero-school-name {
    display: block;
    font-family: 'Outfit', sans-serif;
    font-weight: 600;
    line-height: 1.05;
    letter-spacing: 0.06em;
    color: #fff;
    font-size: clamp(2.4rem, 7vw, 5.5rem);
    text-shadow: 0 4px 30px rgba(0,0,0,0.65), 0 0 90px rgba(153,27,27,0.35);
    white-space: nowrap;
  }
  /* "Secondary School" — centered, pairs with school name */
  .hero-secondary-label {
    display: block;
    font-family: 'Outfit', sans-serif;
    font-weight: 300;
    font-size: clamp(0.85rem, 2.4vw, 1.5rem);
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.85);
    text-shadow: 0 2px 10px rgba(0,0,0,0.55);
  }

  /* ── Gold divider ── */
  .hero-divider {
    height: 1px;
    background: linear-gradient(90deg, transparent, #cb8f24, transparent);
    width: 0;
    opacity: 0;
    margin: 0.25rem 0;
    animation: heroDividerExpand 0.8s cubic-bezier(0.22, 1, 0.36, 1) 1.1s forwards;
  }

  /* ── Tagline ── */
  .hero-tagline {
    font-family: 'Lato', sans-serif;
    font-weight: 300;
    font-size: clamp(0.6rem, 1.8vw, 1rem);
    text-align: center;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.95);
    text-shadow: 0 2px 10px rgba(0,0,0,0.65), 0 1px 3px rgba(0,0,0,0.5);
    white-space: nowrap; /* Ensure tagline stays on one line */
    line-height: 1.8;
    max-width: 38rem;
  }

  /* ── CTA Buttons ── */
  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 1rem;
  }
  .hero-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 9.5rem;
    padding: 0.65rem 1.5rem;
    border-radius: 999px;
    font-family: 'Lato', sans-serif;
    font-weight: 700;
    font-size: clamp(0.6rem, 1.2vw, 0.72rem);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    text-decoration: none;
    transition: transform 0.25s ease, background 0.25s ease, box-shadow 0.25s ease;
    cursor: pointer;
    border: none;
    outline: none;
  }
  .hero-btn:hover { transform: translateY(-3px); }
  .hero-btn--primary {
    background: #961107;
    color: #fff;
    box-shadow: 0 8px 32px rgba(153,27,27,0.35);
  }
  .hero-btn--primary:hover {
    background: #7b0a02;
    box-shadow: 0 12px 40px rgba(153,27,27,0.5);
  }
  .hero-btn--secondary {
    background: rgba(255,255,255,0.10);
    color: #fff;
    border: 1.5px solid rgba(255,255,255,0.30);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }
  .hero-btn--secondary:hover {
    background: rgba(255,255,255,0.20);
    border-color: rgba(255,255,255,0.55);
  }

  /* ════════════════════════════════════════
     STATS BAR – bottom strip
     ════════════════════════════════════════ */
  /* ── Stats bar: pinned to hero bottom ── */
  .hero-stats-bar {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 20;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    background: rgba(10, 15, 30, 0.92);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-top: 1px solid rgba(255,255,255,0.08);
  }
  .hero-stat-card {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.25rem;
    padding: 1.25rem 1rem;
    position: relative;
    opacity: 1;          /* always visible — no animation dependency */
    transition: background 0.3s ease;
  }
  .hero-stat-card:hover { background: rgba(255,255,255,0.05); }

  .hero-stat-icon {
    width: 2.5rem;
    height: 2.5rem;
    background: rgba(153, 27, 27, 0.15);
    border: 1px solid rgba(153, 27, 27, 0.25);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #961107;
    flex-shrink: 0;
    transition: transform 0.3s ease, border-color 0.3s ease, background 0.3s ease;
  }
  .hero-stat-card:hover .hero-stat-icon {
    transform: scale(1.1) rotate(-5deg);
    border-color: #961107;
    background: rgba(153, 27, 27, 0.25);
    color: #fff;
  }
  .hero-stat-icon svg { width: 1.1rem; height: 1.1rem; }

  .hero-stat-info {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }
  .hero-stat-number {
    font-family: 'Bodoni Moda', serif;
    font-weight: 200;
    font-size: clamp(1.2rem, 2.5vw, 1.65rem);
    color: #deb056;
    line-height: 1;
    text-shadow: 0 0 16px rgba(253,230,138,0.35);
  }
  .hero-stat-label {
    font-family: 'Lato', sans-serif;
    font-weight: 800;
    font-size: 0.52rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.60);
    line-height: 1.2;
    white-space: nowrap;
  }

  .hero-stat-divider {
    position: absolute;
    right: 0;
    top: 25%;
    bottom: 25%;
    width: 1px;
    background: linear-gradient(to bottom, transparent, rgba(255,255,255,0.1), transparent);
  }
  .hero-stat-card:last-child .hero-stat-divider { display: none; }

  /* ── Discover More button anchored above chevron ── */
  .hero-bottom-cta {
    position: absolute;
    left: 0;
    right: 0;
    z-index: 20;
    bottom: calc(clamp(3rem, 7vw, 4rem) + 0.25rem + 2.75rem + 0.6rem);
    display: flex;
    justify-content: center;
    align-items: center;
  }

  /* ── Tagline + Button block (flows below heading) ── */
  .hero-bottom-block {
    width: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: clamp(1rem, 2vw, 1.5rem);
    padding: 0 1rem;
  }

  /* ── Scroll indicator ── */
  .hero-scroll-btn {
    position: absolute;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 20;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 9999px;
    border: 1.5px solid rgba(255,255,255,0.28);
    background: rgba(255,255,255,0.08);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    text-decoration: none;
    animation: scrollBounce 2s ease-in-out 2.2s infinite;
    transition: background 0.2s ease, bottom 0.2s ease;
  }
  .hero-scroll-btn:hover { background: rgba(255,255,255,0.20); }
  .hero-scroll-btn svg { width: 1.1rem; height: 1.1rem; }

  @keyframes scrollBounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50%       { transform: translateX(-50%) translateY(6px); }
  }

  /* ════════════════════════════════════════
     Entrance keyframes
     ════════════════════════════════════════ */
  @keyframes heroRevealUp {
    0%   { opacity: 0; transform: translateY(60%) skewY(4deg); filter: blur(8px); }
    55%  { filter: blur(0); }
    100% { opacity: 1; transform: translateY(0) skewY(0deg); filter: blur(0); }
  }
  @keyframes heroDividerExpand {
    0%   { width: 0; opacity: 0; }
    100% { width: clamp(100px, 25vw, 180px); opacity: 1; }
  }
  @keyframes heroFadeUp {
    0%   { opacity: 0; transform: translateY(20px); }
    100% { opacity: 1; transform: translateY(0); }
  }

  .hero-reveal-1 {
    opacity: 0;
    animation: heroRevealUp 0.85s cubic-bezier(0.22, 1, 0.36, 1) 0.3s forwards;
  }
  .hero-reveal-2 {
    opacity: 0;
    animation: heroRevealUp 1s cubic-bezier(0.16, 1, 0.3, 1) 0.55s forwards;
  }
  .hero-reveal-3 {
    opacity: 0;
    animation: heroRevealUp 0.85s cubic-bezier(0.22, 1, 0.36, 1) 0.85s forwards;
  }
  .hero-subtitle-anim {
    opacity: 0;
    animation: heroFadeUp 0.9s cubic-bezier(0.22, 1, 0.36, 1) 1.3s forwards;
  }
  .hero-buttons-anim {
    opacity: 0;
    animation: heroFadeUp 0.9s cubic-bezier(0.22, 1, 0.36, 1) 1.55s forwards;
  }

  /* ════════════════════════════════════════
     MOBILE RESPONSIVE
     ════════════════════════════════════════ */

  /* Tablet: keep 4 cols but smaller */
  /* Tablet: keep 4 cols but smaller */
  @media (max-width: 768px) {
    .hero-stats-bar {
      grid-template-columns: repeat(4, 1fr);
    }
    .hero-stat-card {
      padding: 0.85rem 0.25rem;
    }
    .hero-content-wrapper {
      padding-top: 7rem;
      padding-right: clamp(1.25rem, 5vw, 3rem);
      padding-left: 1.25rem;
      padding-bottom: 1.5rem;
    }
  }

  /* Mobile: 2x2 grid for stats and push the tagline UP so they don't overlap */
  @media (max-width: 640px) {
    .hero-stats-bar {
      grid-template-columns: repeat(2, 1fr);
      border-top: none; 
    }
    .hero-stat-card {
      border-top: 1px solid rgba(255,255,255,0.08);
      padding: 1rem 0.5rem;
      gap: 0.85rem;
    }
    .hero-stat-info {
      min-width: 5.5rem;
      text-align: left;
    }
    .hero-bottom-block {
      gap: 0.75rem;
    }
    .hero-tagline {
      white-space: normal; 
      max-width: 90%;
      line-height: 1.5;
    }
  }

  /* Small mobile: 2×2 grid */
  @media (max-width: 480px) {
    .hero-stats-bar {
      grid-template-columns: repeat(2, 1fr);
    }
    .hero-stat-card:nth-child(2) { border-right: none; }
    .hero-stat-card:nth-child(3) {
      border-right: 1px solid rgba(255,255,255,0.08);
      border-top: 1px solid rgba(255,255,255,0.08);
    }
    .hero-stat-card:nth-child(4) {
      border-top: 1px solid rgba(255,255,255,0.08);
    }
    .hero-content-wrapper {
      padding-right: 1.25rem;
      padding-left: 1.25rem;
      padding-bottom: 1.5rem;
    }
    .hero-ctas {
      flex-direction: column;
      gap: 0.6rem;
    }
    .hero-btn {
      width: 11rem;
    }
  }

  /* ════════════════════════════════════════
     WELCOME SECTION (ws-*)
     ════════════════════════════════════════ */

  /* ── Section label header ── */
  .ws-section-label {
    width: 100%;
    padding: 3rem 0 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.75rem;
  }
  .ws-label-eyebrow {
    font-family: 'Lato', sans-serif;
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: #64748b;
    margin: 0 auto;
  }
  .ws-label-heading {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 400;
    color: #0f172a;
    letter-spacing: 0.02em;
    line-height: 1.15;
    margin: 0 auto;
  }
  .ws-label-rule {
    width: 4rem;
    height: 4px;
    background: #f59e0b;
    border-radius: 999px;
    margin: 0 auto;
  }

  /* ── Mission card (full container width) ── */
  .ws-mission-card {
    background: #fff;
    border: 1px solid #f1f5f9;
    border-radius: 1rem;
    box-shadow: 0 1px 4px rgba(15,23,42,0.06), 0 4px 16px rgba(15,23,42,0.04);
    padding: 2rem;
    width: 100%;           /* matches the grid width — no separate max-w */
    margin-bottom: 4rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }
  @media (min-width: 768px) {
    .ws-mission-card {
      flex-direction: row;
      align-items: center;
      padding: 2.5rem;
    }
  }

  /* ── Red pill badge ── */
  .ws-mission-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.375rem 0.75rem; /* px-3 py-1.5 */
    background: #fef2f2;       /* bg-red-50 */
    color: #b91c1c;            /* text-red-700 */
    border-radius: 999px;      /* rounded-full */
    font-family: 'Lato', sans-serif;
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .ws-mission-badge span {
    font-size: 0.85rem;
    line-height: 1;
  }

  /* ── Mission statement ── */
  .ws-mission-statement {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1rem, 1.8vw, 1.15rem);
    font-weight: 400;
    color: #475569;  /* slate-600 */
    line-height: 1.8;
    margin: 0;
    flex: 1;          /* fills remaining width → no white space on right */
    border-left: none;
    padding-left: 0;
  }
  @media (min-width: 768px) {
    .ws-mission-statement {
      border-left: 1px solid #e2e8f0; /* border-slate-200 */
      padding-left: 1.5rem;           /* pl-6 */
    }
  }

  /* ── Main two-column grid (5/12 photo + 7/12 text) ── */
  .ws-main-grid {
    display: grid;
    grid-template-columns: 1fr;      /* mobile: stack */
    gap: 2.5rem;
    align-items: start;
    margin-bottom: 5rem;
  }
  @media (min-width: 1024px) {
    .ws-main-grid {
      grid-template-columns: 5fr 7fr; /* lg: 5-col photo, 7-col text */
      gap: 3rem;
    }
  }

  /* ── Principal column ── */
  .ws-principal-col { position: relative; }
  .ws-principal-frame {
    position: relative;
    display: flex;
    flex-direction: column;
  }

  /* Floating badge */
  .ws-badge {
    position: absolute;
    top: -1rem;
    right: -1rem;
    z-index: 10;
    background: #fff;
    border: 1px solid #fee2e2;
    box-shadow: 0 8px 24px rgba(153,27,27,0.15);
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.45rem 0.9rem;
  }
  .ws-badge-icon {
    width: 0.9rem;
    height: 0.9rem;
    color: #961107;
    flex-shrink: 0;
  }
  .ws-badge span {
    font-family: 'Lato', sans-serif;
    font-size: 0.55rem;
    font-weight: 900;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #961107;
    white-space: nowrap;
  }

  /* Photo */
  .ws-principal-photo-wrap {
    position: relative;
    overflow: hidden;
    height: clamp(360px, 42vw, 480px);
  }
  .ws-principal-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    transition: transform 0.8s cubic-bezier(0.25, 1, 0.5, 1);
    display: block;
  }
  .ws-principal-photo-wrap:hover .ws-principal-photo { transform: scale(1.04); }
  .ws-photo-sheen {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, transparent 50%, rgba(127,29,29,0.35) 100%);
    pointer-events: none;
  }

  /* Identity card below photo */
  .ws-principal-card {
    display: flex;
    align-items: stretch;
    background: #fff;
    border: 1px solid #f1f5f9;
    box-shadow: 0 16px 48px rgba(15,23,42,0.10);
    position: relative;
    overflow: hidden;
  }
  .ws-principal-card-inner {
    flex: 1;
    padding: 1.25rem 1.5rem;
  }
  .ws-principal-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.25rem, 2.5vw, 1.6rem);
    font-weight: 700;
    color: #f97316 !important;
    margin: 0 0 0.4rem;
    line-height: 1.2;
  }
  .ws-principal-divider {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 0.3rem;
  }
  .ws-principal-rule {
    display: inline-block;
    width: 1.5rem;
    height: 2px;
    background: #cb8f24;
    flex-shrink: 0;
  }
  .ws-principal-role {
    font-family: 'Lato', sans-serif;
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #961107;
  }
  .ws-principal-years {
    font-family: 'Lato', sans-serif;
    font-size: 0.7rem;
    color: #94a3b8;
    margin: 0;
    letter-spacing: 0.05em;
  }
  .ws-principal-card-bar {
    display: none;
  }

  /* Geometric background accent */
  .ws-geo-accent {
    position: absolute;
    bottom: -2rem;
    left: -2rem;
    width: 8rem;
    height: 8rem;
    border: 1px solid #fee2e2;
    transform: rotate(15deg);
    pointer-events: none;
    z-index: -1;
  }

  /* ── Story column ── */
  .ws-story-col {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;   /* space-y-6 */
    padding-top: 0;
  }

  .ws-story-header { display: flex; flex-direction: column; }
  .ws-eyebrow {
    display: inline-block;
    font-family: 'Lato', sans-serif;
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.38em;
    text-transform: uppercase;
    color: #b91c1c;
    margin-bottom: 0.75rem;
  }

  /* Two-line heading stack */
  .ws-story-heading-stack {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .ws-story-heading {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.8rem, 3.5vw, 2.5rem);
    font-weight: 400;
    color: #0f172a;
    line-height: 1.2;
    margin: 0;
    letter-spacing: 0.01em;
  }
  .ws-story-heading--alt {
    color: #334155; /* slate-800 — slightly lighter second line */
  }

  /* ── Principal quote ── */
  .ws-quote-wrap {
    display: flex;
    flex-direction: column;
    max-width: 32rem;   /* max-w-2xl */
    margin-top: 0.5rem;
  }
  .ws-quote {
    border-left: 4px solid #b91c1c; /* border-red-700 — spans full height */
    padding-left: 1.5rem;           /* pl-6 */
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;                      /* space-y-4 */
  }

  /* Decorative opening quote mark */
  .ws-quote-mark {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2.5rem;
    line-height: 1;
    color: #fecaca;  /* text-red-200 */
    display: block;
    height: 1rem;    /* h-4 — keeps it compact, text rides above */
    user-select: none;
    pointer-events: none;
  }

  /* Italic serif body */
  .ws-quote-body {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1rem, 1.8vw, 1.1rem);
    font-style: italic;
    font-weight: 400;
    color: #334155;  /* slate-700 */
    line-height: 1.75;
    margin: 0;
  }

  /* Author cite block */
  .ws-quote-cite {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;  /* mt-0.5 gap between name and role */
    padding-top: 0.5rem;
    font-style: normal;
  }
  .ws-quote-name {
    font-family: 'Lato', sans-serif;
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #d97706;  /* text-amber-600 */
    display: block;
  }
  .ws-quote-role {
    font-family: 'Lato', sans-serif;
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #94a3b8;  /* text-slate-400 */
    display: block;
  }

  /* ── Value pillars ── */
  .ws-pillars {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .ws-pillar {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1rem;
    border: 1px solid #f1f5f9;
    background: #fff;
    transition: border-color 0.25s ease, box-shadow 0.25s ease, transform 0.25s ease;
  }
  .ws-pillar:hover {
    border-color: #fecaca;
    box-shadow: 0 8px 24px rgba(153,27,27,0.08);
    transform: translateX(4px);
  }
  .ws-pillar-icon-wrap {
    width: 2.5rem;
    height: 2.5rem;
    background: #fff5f5;
    border: 1px solid #fee2e2;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: #961107;
    transition: background 0.25s ease, border-color 0.25s ease;
  }
  .ws-pillar:hover .ws-pillar-icon-wrap {
    background: #961107;
    border-color: #961107;
    color: #fff;
  }
  .ws-pillar-icon-wrap svg { width: 1rem; height: 1rem; }
  .ws-pillar-title {
    font-family: 'Lato', sans-serif;
    font-size: 0.72rem;
    font-weight: 900;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #0f172a;
    margin: 0 0 0.2rem;
  }
  .ws-pillar-desc {
    font-family: 'Lato', sans-serif;
    font-size: 0.75rem;
    color: #64748b;
    line-height: 1.6;
    margin: 0;
  }

  /* ── CTAs ── */
  .ws-cta {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  .ws-cta-link {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1.75rem;
    background: #961107;
    color: #fff;
    font-family: 'Lato', sans-serif;
    font-size: 0.65rem;
    font-weight: 900;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    text-decoration: none;
    transition: background 0.25s ease, transform 0.25s ease, box-shadow 0.25s ease;
    box-shadow: 0 6px 20px rgba(153,27,27,0.30);
  }
  .ws-cta-link:hover {
    background: #7b0a02;
    transform: translateY(-2px);
    box-shadow: 0 10px 28px rgba(153,27,27,0.40);
  }
  .ws-cta-arrow {
    display: flex;
    align-items: center;
  }
  .ws-cta-arrow svg { width: 1rem; height: 1rem; }
  .ws-cta-secondary {
    font-family: 'Lato', sans-serif;
    font-size: 0.65rem;
    font-weight: 900;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: #961107;
    text-decoration: none;
    border-bottom: 1.5px solid #961107;
    padding-bottom: 1px;
    transition: color 0.2s ease, border-color 0.2s ease;
  }
