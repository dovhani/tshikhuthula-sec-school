<script>
    /* ── Stat counter animation ── */
    function initStats() {
        const statNumbers = document.querySelectorAll<HTMLElement>('.stat-number');
        if (!statNumbers.length) return;

        const animate = (el: HTMLElement) => {
            const target   = parseInt(el.dataset.target  ?? '0', 10);
            const suffix   = el.dataset.suffix ?? '';
            const duration = 2000;
            const start    = performance.now();

            const tick = (now: number) => {
                const p   = Math.min((now - start) / duration, 1);
                const exp = p === 1 ? 1 : 1 - Math.pow(2, -10 * p);
                const val = Math.floor(exp * target);
                el.textContent = val.toLocaleString() + (p < 1 ? '' : suffix);
                if (p < 1) requestAnimationFrame(tick);
            };
            requestAnimationFrame(tick);
        };

        const io = new IntersectionObserver((entries) => {
            entries.forEach(e => {
                if (e.isIntersecting) {
                    statNumbers.forEach(animate);
                    io.disconnect();
                }
            });
        }, { threshold: 0.1 });

        io.observe(document.getElementById('hero') ?? document.body);
    }

    /* ── Hero image slider ── */
    function initHeroSlider() {
        const slides = Array.from(
            document.querySelectorAll<HTMLElement>('.hero-slider .slide')
        );
        if (slides.length < 2) return;

        let current = 0;
        setInterval(() => {
            slides[current].classList.remove('active-slide');
            current = (current + 1) % slides.length;
            slides[current].classList.add('active-slide');
        }, 5000);
    }

    /* ── Welcome section scroll-reveal ── */
    function initWelcomeReveal() {
        // ws-reveal elements
        const wsReveals = Array.from(
            document.querySelectorAll<HTMLElement>('.ws-reveal')
        );
        if (wsReveals.length) {
            const ioWs = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        const el = entry.target as HTMLElement;
                        const idx = wsReveals.indexOf(el);
                        setTimeout(() => { el.classList.add('ws-visible'); }, idx * 120);
                        ioWs.unobserve(el);
                    }
                });
            }, { threshold: 0.12 });
            wsReveals.forEach(el => ioWs.observe(el));
        }

        // sh-reveal elements (highlights + news)
        const shReveals = Array.from(
            document.querySelectorAll<HTMLElement>('.sh-reveal')
        );
        if (shReveals.length) {
            const ioSh = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        const el = entry.target as HTMLElement;
                        const idx = shReveals.indexOf(el);
                        setTimeout(() => { el.classList.add('sh-visible'); }, idx * 100);
                        ioSh.unobserve(el);
                    }
                });
            }, { threshold: 0.10 });
            shReveals.forEach(el => ioSh.observe(el));
        }
    }

    initStats();
    initHeroSlider();
    initWelcomeReveal();
    document.addEventListener('astro:after-swap', () => {
        initStats();
        initHeroSlider();
        initWelcomeReveal();
    });
</script>
