---
import Layout from '../layouts/Layout.astro';
import SecondaryNav from '../components/SecondaryNav.astro';
import '../styles/about.css';

const timeline = [
    { year: "1967", title: "School Founded", description: "Tshikhuthula Secondary School opens its doors to the community, establishing a legacy of rural educational empowerment." },
    { year: "2002", title: "Infrastructure Milestone", description: "Inauguration of the main academic wing and foundational science facilities." },
    { year: "2010", title: "Academic Expansion", description: "Broadening the curriculum to include comprehensive STEM and Commercial streams." },
    { year: "2018", title: "Modernization Initiative", description: "Introduction of digital learning labs and enhanced sports infrastructure." },
    { year: "2023", title: "Silver Jubilee Excellence", description: "Celebrating over 25 years of nurturing leaders with record-breaking matric results." },
    { year: "2024", title: "Future Forward", description: "Launching new vocational training programs and sustainable green campus initiatives." }
];

const values = [
    { 
        icon: `<svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" /></svg>`, 
        title: "Academic Rigor", 
        description: "Upholding the highest standards of intellectual curiosity and scholastic achievement." 
    },
    { 
        icon: `<svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>`, 
        title: "Unwavering Integrity", 
        description: "Cultivating honesty, accountability, and ethical leadership in every student." 
    },
    { 
        icon: `<svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" /></svg>`, 
        title: "Mutual Respect", 
        description: "Fostering an inclusive environment where every voice is heard and every person is valued." 
    }
];

const facilities = [
    { 
        icon: `<svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.628.288a2 2 0 01-1.908 0l-.628-.288a6 6 0 00-3.86-.517l-2.387.477a2 2 0 00-1.022.547l-1.162 1.162a2 2 0 001.414 3.414h15.414a2 2 0 001.414-3.414l-1.162-1.162zM16.5 5V4a1 1 0 00-1-1h-7a1 1 0 00-1 1v1m3 0a1 1 0 011-1h1a1 1 0 011 1m3 0l.392 2.352a2 2 0 01-.204 1.357l-1.027 1.782A2 2 0 0113.807 11H10.193a2 2 0 01-1.854-1.259l-1.027-1.782a2 2 0 01-.204-1.357L7.5 5" /></svg>`, 
        title: "STEM Laboratories", 
        description: "State-of-the-art facilities for advanced scientific research and experimentation." 
    },
    { 
        icon: `<svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>`, 
        title: "IT Innovation Hub", 
        description: "High-speed digital labs equipped for coding, robotics, and multimedia design." 
    },
    { 
        icon: `<svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" /></svg>`, 
        title: "Media Resource Centre", 
        description: "An extensive collection of physical and digital knowledge archives." 
    },
    { 
        icon: `<svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`, 
        title: "Sports Arena", 
        description: "Professional-grade athletic fields and indoor recreational spaces." 
    }
];
---

<Layout title="About Us - Tshikhuthula Secondary School" currentPage="about" noNavbarPadding={true} showMainNav={true}>
    
    <!-- ── Page Header ── -->
    <header class="ab-header ws-reveal">
        <div class="ab-header-bg"></div>
        <div class="ab-header-content">
            <div class="inline-flex items-center gap-3 px-5 py-2 rounded-full border border-gold-500/30 bg-gold-500/10 backdrop-blur-md mb-6">
                <span class="text-[10px] font-black uppercase tracking-[0.3em] text-gold-400">Our Heritage</span>
            </div>
            <h1 class="text-5xl md:text-7xl font-heading text-white font-display drop-shadow-lg tracking-tight mb-6">
                Our Story & <span class="text-transparent bg-clip-text bg-gradient-to-r from-gold-400 to-gold-600">Spirit</span>
            </h1>
            <p class="text-slate-300 max-w-3xl mx-auto text-lg leading-relaxed font-lato">
                Discover the legacy of excellence that defines Tshikhuthula Secondary School — a journey of nurturing minds and empowering leaders since 1967.
            </p>
        </div>
    </header>

    <!-- ── Mission & Vision Banner ── -->
    <section class="ab-mission-section ws-reveal">
        <div class="ab-mission-banner">
            <div class="ab-mission-item">
                <div class="ab-mission-label">
                    <svg class="ab-mission-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z" />
                    </svg>
                    <span>Our Mission</span>
                </div>
                <p class="ab-mission-text">
                    To provide a nurturing, inclusive, and stimulating learning environment that empowers students to achieve academic excellence, develop strong character, and become responsible global citizens.
                </p>
            </div>
            
            <div class="ab-mission-divider"></div>

            <div class="ab-mission-item">
                <div class="ab-mission-label">
                    <svg class="ab-mission-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
                    </svg>
                    <span>Our Vision</span>
                </div>
                <p class="ab-mission-text">
                    To be a premier educational institution recognized for developing innovative thinkers, compassionate leaders, and lifelong learners who contribute positively to society.
                </p>
            </div>
        </div>
    </section>

    <!-- ── History Timeline ── -->
    <section class="ab-timeline-section max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
        <div class="ab-section-label text-center items-center mb-12 ws-reveal">
            <span class="ab-label-eyebrow">The Journey</span>
            <h2 class="ab-label-heading">A Legacy in Motion</h2>
            <div class="ab-label-rule mx-auto"></div>
        </div>

        <div class="ab-timeline">
            {timeline.map((item, i) => (
                <div class={`ab-timeline-item ws-reveal ${i % 2 === 0 ? 'ab-timeline-left' : 'ab-timeline-right'}`}>
                    <div class="ab-timeline-content">
                        <div class="ab-timeline-year">{item.year}</div>
                        <h3 class="ab-timeline-title">{item.title}</h3>
                        <p class="ab-timeline-desc">{item.description}</p>
                    </div>
                    <div class="ab-timeline-dot"></div>
                </div>
            ))}
        </div>
    </section>

    <!-- ── Core Values ── -->
    <section class="ab-values-section bg-slate-50 py-16 relative overflow-hidden">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="ab-section-label mb-12 ws-reveal">
                <span class="ab-label-eyebrow">Internal Compass</span>
                <h2 class="ab-label-heading">Our Core Pillars</h2>
                <div class="ab-label-rule"></div>
            </div>

            <div class="ab-grid">
                {values.map((val, i) => (
                    <div class={`ab-card ws-reveal delay-${i+1}`}>
                        <div class="ab-card-icon" set:html={val.icon} />
                        <h3 class="ab-card-title">{val.title}</h3>
                        <p class="ab-card-desc">{val.description}</p>
                        <div class="ab-card-rule"></div>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- ── Facilities ── -->
    <section class="ab-facilities-section py-16 bg-white">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="ab-section-label text-right items-end mb-12 ws-reveal">
                <span class="ab-label-eyebrow">The Campus</span>
                <h2 class="ab-label-heading">World Class Environment</h2>
                <div class="ab-label-rule"></div>
            </div>

            <div class="ab-facility-grid">
                {facilities.map((fac, i) => (
                    <div class={`ab-facility-card ws-reveal delay-${i+1}`}>
                        <div class="ab-facility-icon-side" set:html={fac.icon} />
                        <div class="ab-facility-info">
                            <h3 class="ab-facility-title">{fac.title}</h3>
                            <p class="ab-facility-desc">{fac.description}</p>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </section>

</Layout>

<script>
    // Initialize standard reveal for about page
    function initAboutReveal() {
        const observerOptions = {
            threshold: 0.1,
            rootMargin: '0px 0px -50px 0px'
        };

        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('reveal-active');
                    observer.unobserve(entry.target);
                }
            });
        }, observerOptions);

        document.querySelectorAll('.ws-reveal').forEach(el => observer.observe(el));
    }

    document.addEventListener('DOMContentLoaded', initAboutReveal);
</script>
